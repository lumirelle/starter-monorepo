amends "package://github.com/jdx/hk/releases/download/v1.46.0/hk@1.46.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.46.0/hk@1.46.0#/Builtins.pkl"

local linters = new Mapping<String, Step> {
  // JS & TS & ...
    ["oxlint"] = (Builtins.ox_lint) {
      check = "oxlint --no-error-on-unmatched-pattern --deny-warnings {{ files }}"
      fix = "oxlint --no-error-on-unmatched-pattern --deny-warnings --fix {{ files }}"
    }
    ["eslint"] = (Builtins.eslint) {
      batch = false
    glob =
      List(
        // JS & TS
        "*.js",
        "*.mjs",
        "*.cjs",
        "*.jsx",
        "*.ts",
        "*.mts",
        "*.cts",
        "*.tsx",
        // Markdown
        "*.md",
        "*.mdc",
        "*.mdx",
        // JSON
        "*.json",
        "*.jsonc",
        // YAML
        "*.yaml",
        "*.yml",
        // TOML
        "*.toml",
      )
      check = "eslint --no-warn-ignored {{ files }}"
      fix = "eslint --no-warn-ignored --fix {{ files }}"
      depends = List("oxlint")
    }
    ["tsc"] = Builtins.tsc

    ["knip"] = (Builtins.knip) {
      workspace_indicator = "knip.config.ts"
      check = "knip-bun --no-progress --directory {{workspace}}"
      fix = "knip-bun --fix --no-progress --directory {{workspace}}"
    }

}

hooks {
    ["pre-commit"] {
        fix = true
        stash = "git"
        steps = linters
    }
    ["fix"] {
        fix = true
        steps = linters
    }
    ["check"] {
        steps = linters
    }
}
